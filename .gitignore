# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# storybook
/storybook-static
*storybook.log

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
# next-env.d.ts is auto-generated but committed for CI compatibility

# local tool state (claude code / oh-my-claudecode)
.claude/settings.local.json
.omc/

# AI Agent Related
.agents/

# Uncommitted Related
.uncommitted/

# AI tool state / worktrees / local docs
.antigravitycli/
.claude/worktrees/
docs/superpowers/

# playwright MCP scratch output
.playwright-mcp/

# local design prototypes (not committed on this branch)
docs/prototypes/

# graphify: commit shareable outputs (graph.json, graph.html, GRAPH_REPORT.md);
# ignore machine-specific / regenerable state
graphify-out/.graphify_*
graphify-out/cache/
graphify-out/cost.json
graphify-out/manifest.json
