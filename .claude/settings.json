{
  "hooks": {
    "FileChanged": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint . --fix"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint . && npm run build"
          }
        ]
      }
    ]
  }
}
