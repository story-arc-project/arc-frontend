NEXT_PUBLIC_API_URL=http://localhost:8000

# E2E 테스트 전용 인증 훅 (FRT-24)
# true로 설정하면 fetchCurrentUser()가 로그인 플로우 없이 고정 사용자를 반환해
# (main) 진입을 E2E에서 검증할 수 있다. 기본값은 off이며, production/preview에는 설정하지 않는다.
NEXT_PUBLIC_E2E_AUTH=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
