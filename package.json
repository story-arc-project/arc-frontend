{
  "name": "arc-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook --failOnConsole",
    "test-storybook:ci": "node scripts/assert-port-free.mjs 6006 && concurrently -k -s first -n SB,TEST -c magenta,blue \"npm run build-storybook -- --quiet && npx http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && npm run test-storybook\"",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "pretest:e2e:ui": "playwright install chromium",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.51.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@storybook/nextjs": "^10.4.2",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "storybook": "^10.4.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
